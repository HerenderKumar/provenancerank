# Copy to `.env` and fill in. NEVER commit a real .env (see .gitignore).

# --- LLM provider (offline only — JD parse, summaries, grading, NL query) ---
# auto order: GLM -> local Ollama -> Gemini -> heuristic. Blank => heuristics.
LLM_PROVIDER=auto                     # auto | glm | ollama | gemini | none
GLM_API_KEY=                          # Z.ai / Zhipu GLM key (used FIRST when set)
GLM_MODEL=glm-5.2
GLM_BASE_URL=https://api.z.ai/api/paas/v4
OLLAMA_BASE_URL=http://localhost:11434  # Docker: http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b              # any model you've `ollama pull`-ed
GOOGLE_API_KEY=                       # optional Gemini fallback
JD_DECONSTRUCT_MODEL=gemini-1.5-flash
PSEUDO_LABEL_LLM_ENABLED=false        # opt in to LLM label grading (slower)

# --- Embedding model (local, no API) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=512
ALLOW_REMOTE_EMBEDDINGS=false         # true => may download the ST model

# --- Paths ---
ARTIFACTS_DIR=./artifacts
CANDIDATES_FILE=./candidates.jsonl
JD_FILE=./data/job_description.txt

# --- Final-score merge weights (sum to 1.0) ---
ML_SCORE_WEIGHT=0.40
RETRIEVAL_SCORE_WEIGHT=0.35
SIGNAL_SCORE_WEIGHT=0.25

# --- Loop agent ---
MAX_LOOP_ITERATIONS=4
CONFIDENCE_THRESHOLD=0.80

# --- Pipeline ---
STREAM_BATCH_SIZE=1000
RANDOM_SEED=42
LOG_LEVEL=INFO

# --- API (sandbox only) ---
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://redis:6379/0

# --- Live ingestion layer (addendum) ---
GITHUB_TOKEN=                          # ghp_...  classic PAT, scopes: public_repo + read:user
STACKOVERFLOW_API_KEY=
NEO4J_ENABLED=false                    # true => use Neo4j; false => in-memory graph
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=provenancerank
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=true          # true => run tasks inline (no worker); false in prod
MAX_REPOS_PER_DEVELOPER=20
MAX_COMMITS_PER_REPO=50
SYNC_INTERVAL_HOURS=6
EVIDENCE_CONFIDENCE_BONUS=0.15         # rank boost for graph-verified candidates
